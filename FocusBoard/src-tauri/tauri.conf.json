{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "focusboard",
  "version": "0.1.0",
  "identifier": "com.adarssh.focusboard",
  "build": {
    "beforeDevCommand": "bun --cwd src dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun --cwd src build",
    "frontendDist": "../src/dist"
  },
  "app": {
    "windows": [
      {
        "title": "focusboard",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "pattern":{
        "use": "brownfield"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {}
  }
}
